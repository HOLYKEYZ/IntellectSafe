{
  "manifest_version": 3,
  "name": "IntellectSafe Companion",
  "version": "1.1",
  "description": "Secures your AI chat sessions. Scans prompts & outputs (Allow-and-Retract mode).",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
"host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://grok.com/*",
    "http://localhost:8001/*",
    "http://127.0.0.1:8001/*",
    "https://api.intellectsafe.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
