# IntellectSafe Environment Variables
# Copy this file to .env and fill in your values

# ============ Required API Keys ============
# Get keys from https://console.anthropic.com/ (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Get keys from https://aistudio.google.com/app/apikey (Google AI Studio)
GEMINI_API_KEY=AIza...
GEMINI2_API_KEY=AIza...

# Get keys from https://console.groq.com/ (Groq)
GROQ_API_KEY=gsk_...
GROK2_API_KEY=

# Get keys from https://openrouter.ai/keys (OpenRouter)
OPENROUTER_API_KEY=sk-or-...

# OpenAI (optional - for testing)
OPENAI_API_KEY=sk-...


# ============ Database ============
DATABASE_URL=sqlite:///./sql_app.db
# Or PostgreSQL: postgresql://user:password@localhost:5432/intellectsafe


# ============ Redis (for rate limiting) ============
REDIS_URL=redis://localhost:6379


# ============ Optional Configuration ============
# Skip API key tests in local dev (set to 1 to skip)
SKIP_API_TESTS=0

# Safety-specific provider (optional)
# Use a dedicated API key for safety scanning to separate costs
# SAFETY_SPECIFIC_PROVIDER=openrouter

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3002

# Backend URL
BACKEND_URL=http://localhost:8001
